{
	"id": "drag-ruler-modern",
	"title": "Drag Ruler Modern",
	"description": "When dragging a token displays a ruler showing how far you've moved that token.",
	"version": "1.0.0",
	"compatibility": {
		"minimum": "13",
		"verified": "13.346"
	},
	"authors": [
		{
			"name": "Manuel Vögele",
			"email": "develop@manuel-voegele.de",
			"discord": "stabchenfisch"
		}
	],
	"esmodules": [
		"src/libwrapper_shim.js",
		"src/main.js",
		"src/socket.js"
	],
	"templates": [
		"speed_provider_settings.html"
	],
	"languages": [
		{
			"lang": "en",
			"name": "English",
			"path": "lang/en.json"
		},
		{
			"lang": "de",
			"name": "Deutsch",
			"path": "lang/de.json"
		},
		{
			"lang": "es",
			"name": "Español",
			"path": "lang/es.json"
		},
		{
			"lang": "fr",
			"name": "Français",
			"path": "lang/fr.json"
		},
		{
			"lang": "ja",
			"name": "日本語",
			"path": "lang/ja.json"
		},
		{
			"lang": "ko",
			"name": "한국어",
			"path": "lang/ko.json"
		},
		{
			"lang": "pt-BR",
			"name": "Português (Brasil)",
			"path": "lang/pt_BR.json"
		},
		{
			"lang": "zh-Hans",
			"name": "中文（简体）",
			"path": "lang/zh_Hans.json"
		},
		{
			"lang": "zh-TW",
			"name": "中文（繁體）",
			"path": "lang/zh-tw.json"
		}
	],
	"relationships": {
		"requires": [
			{
				"id": "lib-wrapper",
				"type": "module",
				"compatibility": {
					"minimum": "1.12.0"
				}
			},
			{
				"id": "socketlib",
				"type": "module",
        "manifest": "https://raw.githubusercontent.com/manuelVo/foundryvtt-socketlib/master/module.json",
        "compatibility": {
          "verified": "1.1.3"
        }
			}
		]
	},
	"socket": true,
	"url": "https://github.com/manuelVo/foundryvtt-drag-ruler",
	"download": "https://github.com/manuelVo/foundryvtt-drag-ruler/archive/v1.13.8.zip",
	"manifest": "https://raw.githubusercontent.com/manuelVo/foundryvtt-drag-ruler/master/module.json",
	"readme": "https://github.com/manuelVo/foundryvtt-drag-ruler/blob/master/README.md",
	"changelog": "https://github.com/manuelVo/foundryvtt-drag-ruler/blob/master/CHANGELOG.md",
	"bugs": "https://github.com/manuelVo/foundryvtt-drag-ruler/issues",
	"allowBugReporter": true
}
